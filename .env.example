ENVIRONMENT=production
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@host.docker.internal/gymtracker
DB_ECHO=false
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=YOUR_64_CHAR_SECRET_STRING_HERE_CHANGE_ME_TO_SECURE_RANDOM_VALUE
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage (local para dev, s3 para prod)
STORAGE_BACKEND=local
MEDIA_DIR=media
MEDIA_BASE_URL=http://localhost:8000/media
MAX_UPLOAD_SIZE_MB=10

# S3 (apenas quando STORAGE_BACKEND=s3)
S3_BUCKET=gymtracker-media
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
