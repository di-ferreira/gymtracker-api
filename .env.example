# Production Environment Configuration for GymTracker API

# Server Configuration
DEBUG=false
ENVIRONMENT=production

# Database (postgresql+asyncpg:// for async support)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@host.docker.internal/gymtracker
DB_ECHO=false

# Security (Generate with python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=YOUR_64_CHAR_SECRET_STRING_HERE_CHANGE_ME_TO_SECURE_RANDOM_VALUE

# CORS Configuration (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

Optional Production Settings:
JWT_SECRET_KEY=PLACEHOLDER_REPLACE_WITH_SECURE_RANDOM_TOKEN
LOG_LEVEL=INFO
LOG_FORMAT=json
